# MedGuard360 — environment template for docker-compose
# Copy to .env and edit. NEVER commit .env.

# ---- Core ----
NODE_ENV=development

# ---- Postgres ----
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=medguard360
PG_USER=medguard
PG_PASSWORD=medguard-dev-only-change-me
PG_POOL_MAX=20
PG_SSL=false

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Kafka ----
KAFKA_BROKERS=kafka:9092

# ---- JWT ----
# Generate with: openssl rand -base64 48
JWT_SECRET=dev-secret-please-rotate-min-32-chars-1234567890
JWT_ISSUER=medguard360
JWT_AUDIENCE=medguard360-platform
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# ---- MinIO ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_SSL=false
MINIO_ACCESS_KEY=medguard
MINIO_SECRET_KEY=medguard-dev-only-change-me
MINIO_URL=http://minio:9000

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=/api
MEDGUARD_API_BASE=http://nginx/api

# ============================================================
# Real-integration env vars (all optional — without them, dev stubs run)
# ============================================================

# ---- Clerk (identity) ----
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ---- Biometric vendor ----
# BIOMETRIC_VENDOR=suprema | nec | stub
# BIOMETRIC_SCORE_THRESHOLD=0.92
# BIOMETRIC_LIVENESS_THRESHOLD=0.80
# SUPREMA_API_BASE=https://biostar.medguard360.local/api/v2
# SUPREMA_API_KEY=...
# NEC_API_BASE=https://neoface.medguard360.local/api/v1
# NEC_API_TOKEN=...

# Per-state vendor override (e.g. NC uses Suprema, GA uses NEC):
# BIOMETRIC_VENDOR_NC=suprema
# BIOMETRIC_VENDOR_GA=nec

# ---- Notification vendors ----
# AWS_REGION=us-east-1
# SES_FROM_ADDRESS=noreply@medguard360.com
# SES_CONFIGURATION_SET=medguard360-prod
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15555550100
# FCM_PROJECT_ID=...
# FCM_CLIENT_EMAIL=firebase-adminsdk@....iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Clearinghouse for 837P submission ----
# CLEARINGHOUSE=change_healthcare | availity | trizetto | generic_rest | stub
# CHANGE_HEALTHCARE_API=https://apis.changehealthcare.com/medicalnetwork/claims/professional/v1/submission
# CHANGE_HEALTHCARE_TOKEN=...
# AVAILITY_API=https://api.availity.com/v3/edi-submissions
# AVAILITY_TOKEN=...
# TRIZETTO_SFTP_HOST=sftp.trizetto.com
# GENERIC_CLEARINGHOUSE_URL=...
# GENERIC_CLEARINGHOUSE_AUTH="Bearer ..."
# Per-payer override: CLEARINGHOUSE_<payerId>=availity

# ---- 837P billing entity (used as ISA sender + provider on x12 270) ----
# MEDGUARD_BILLING_NPI=1234567890
# MEDGUARD_BILLING_NAME=MedGuard360 Inc

# ---- HETS (HIPAA Eligibility Transaction System) — CMS Medicare 270/271 ----
# Effective 2026-05-11, CMS HETS Trading Partner Management System requires
# every Medicare 270/271 to carry the originating submitter's HETS UID in ISA06.
# Until MedGuard360 receives its assigned UID from CMS, use the placeholder.
# When AAA error 41 is received in a 271 response, the affected provider's
# NPI has not been attested under this submitter UID — block Medicare
# eligibility checks for that NPI until attestation completes.
# HETS_SUBMITTER_UID=MEDGUARD360_PENDING_UID

# ---- NCTracks (NC Medicaid MMIS — GDIT) ----
# Demo default: stub (deterministic responses). Flip to soap/sftp after TPA onboarding.
# NCTRACKS_MODE=stub
# NCTRACKS_ENV=test
# NCTRACKS_TPID=                              # issued by GDIT after TPA
# NCTRACKS_SUBMITTER_ID=                      # TSN (ISA06/GS02)
# NCTRACKS_SUBMITTER_QUALIFIER=ZZ
# NCTRACKS_RECEIVER_ID=NCXIX
# NCTRACKS_RECEIVER_QUALIFIER=ZZ
# NCTRACKS_BILLING_TAXONOMY=261Q00000X
# NCTRACKS_ATYPICAL_ID=
# NCTRACKS_REALTIME_ELIGIBILITY_URL=           # partner-gated SOAP endpoint
# NCTRACKS_REALTIME_CLAIMSTATUS_URL=
# NCTRACKS_BATCH_SFTP_HOST=
# NCTRACKS_BATCH_SFTP_USER=
# NCTRACKS_SFTP_PRIVATE_KEY=
# NCTRACKS_CLIENT_CERT=
# NCTRACKS_CLIENT_KEY=
# Set NCTRACKS_MODE=disabled to bypass adapter and use generic MMIS path for NC.
