# MedGuard360 — environment template for docker-compose
# Copy to .env and edit. NEVER commit .env.

# ---- Core ----
NODE_ENV=development

# ---- Postgres ----
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=medguard360
PG_USER=medguard
PG_PASSWORD=medguard-dev-only-change-me
PG_POOL_MAX=20
PG_SSL=false

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Kafka ----
KAFKA_BROKERS=kafka:9092

# ---- JWT ----
# Generate with: openssl rand -base64 48
JWT_SECRET=dev-secret-please-rotate-min-32-chars-1234567890
JWT_ISSUER=medguard360
JWT_AUDIENCE=medguard360-platform
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# ---- MinIO ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_SSL=false
MINIO_ACCESS_KEY=medguard
MINIO_SECRET_KEY=medguard-dev-only-change-me
MINIO_URL=http://minio:9000

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=/api
MEDGUARD_API_BASE=http://nginx/api

# ============================================================
# Real-integration env vars (all optional — without them, dev stubs run)
# ============================================================

# ---- Clerk (identity) ----
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ---- Biometric vendor ----
# BIOMETRIC_VENDOR=suprema | nec | stub
# BIOMETRIC_SCORE_THRESHOLD=0.92
# BIOMETRIC_LIVENESS_THRESHOLD=0.80
# SUPREMA_API_BASE=https://biostar.medguard360.local/api/v2
# SUPREMA_API_KEY=...
# NEC_API_BASE=https://neoface.medguard360.local/api/v1
# NEC_API_TOKEN=...

# Per-state vendor override (e.g. NC uses Suprema, GA uses NEC):
# BIOMETRIC_VENDOR_NC=suprema
# BIOMETRIC_VENDOR_GA=nec

# ---- Notification vendors ----
# AWS_REGION=us-east-1
# SES_FROM_ADDRESS=noreply@medguard360.com
# SES_CONFIGURATION_SET=medguard360-prod
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15555550100
# FCM_PROJECT_ID=...
# FCM_CLIENT_EMAIL=firebase-adminsdk@....iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Clearinghouse for 837P submission ----
# CLEARINGHOUSE=change_healthcare | availity | trizetto | generic_rest | stub
# CHANGE_HEALTHCARE_API=https://apis.changehealthcare.com/medicalnetwork/claims/professional/v1/submission
# CHANGE_HEALTHCARE_TOKEN=...
# AVAILITY_API=https://api.availity.com/v3/edi-submissions
# AVAILITY_TOKEN=...
# TRIZETTO_SFTP_HOST=sftp.trizetto.com
# GENERIC_CLEARINGHOUSE_URL=...
# GENERIC_CLEARINGHOUSE_AUTH="Bearer ..."
# Per-payer override: CLEARINGHOUSE_<payerId>=availity

# ---- 837P billing entity (used as ISA sender + provider on x12 270) ----
# MEDGUARD_BILLING_NPI=1234567890
# MEDGUARD_BILLING_NAME=MedGuard360 Inc
