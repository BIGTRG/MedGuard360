{
  "name": "@medguard360/auth-service",
  "version": "0.1.0",
  "description": "JWT, Clerk, biometric tokens, RBAC — port 3001",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@medguard360/shared": "file:../../packages/shared",
    "bcrypt": "^5.1.1",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.4.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
